{
    "_version": "1.0.0",
    "_description": "C++ HFT Trader Risk & Analysis Configuration",

    "symbol_scoring": {
        "enabled": true,
        "min_trades": 20,
        "rescore_interval_hours": 6,
        "weights": {
            "expectancy": 0.35,
            "profit_factor": 0.25,
            "win_rate": 0.20,
            "consistency": 0.10,
            "frequency_quality": 0.10
        },
        "tier_thresholds": {
            "S": 75, "A": 60, "B": 45, "C": 30, "D": 15
        },
        "tier_size_multiplier": {
            "S": 1.0, "A": 1.0, "B": 0.75, "C": 0.50, "D": 0.0, "X": 0.0
        },
        "tier_max_leverage": {
            "S": 20, "A": 15, "B": 10, "C": 7, "D": 0, "X": 0
        }
    },

    "position_sizing": {
        "method": "kelly_risk_hybrid",
        "kelly_fraction": 0.25,
        "max_risk_per_trade_pct": 2.0,
        "min_trade_usdt": 5.0,
        "max_trade_usdt": 50.0,
        "default_trade_usdt": 10.0,
        "drawdown_levels": [
            {"threshold": 3.0,   "multiplier": 1.0},
            {"threshold": 5.0,   "multiplier": 0.75},
            {"threshold": 8.0,   "multiplier": 0.50},
            {"threshold": 12.0,  "multiplier": 0.25},
            {"threshold": 100.0, "multiplier": 0.0}
        ]
    },

    "fee_analysis": {
        "taker_fee_pct": 0.06,
        "maker_fee_pct": 0.02,
        "funding_rate_default_pct": 0.01,
        "slippage_tiers": {
            "major": {
                "symbols": ["BTCUSDT", "ETHUSDT", "SOLUSDT", "BNBUSDT", "XRPUSDT"],
                "base_bps": 0.5
            },
            "mid": {
                "base_bps": 1.5
            },
            "altcoin": {
                "base_bps": 3.0
            }
        },
        "min_tp_to_cost_ratio": 2.0
    },

    "portfolio_risk": {
        "max_positions_total": 100,
        "max_positions_per_tf": {
            "1": 20, "5": 25, "15": 20, "30": 15, "60": 10, "240": 6
        },
        "tf_exposure_pct": {
            "1": 15, "5": 30, "15": 25, "30": 20, "60": 15, "240": 10
        },
        "correlation_factor": 0.7,
        "max_correlated_risk_pct": 80.0,
        "circuit_breaker": {
            "daily_loss_pct": 5.0,
            "weekly_loss_pct": 10.0,
            "cooldown_minutes": 60
        }
    },

    "tf_filters": {
        "1":   {"size_multiplier": 0.35, "min_tier": "C", "min_tp_to_cost_ratio": 2.5, "block_reverse": true},
        "5":   {"size_multiplier": 0.65, "min_tier": "C", "min_tp_to_cost_ratio": 2.0, "block_reverse": true},
        "15":  {"size_multiplier": 1.0,  "min_tier": "C", "min_tp_to_cost_ratio": 1.5, "block_reverse": true},
        "30":  {"size_multiplier": 1.0,  "min_tier": "C", "min_tp_to_cost_ratio": 1.5, "block_reverse": false},
        "60":  {"size_multiplier": 1.0,  "min_tier": "C", "min_tp_to_cost_ratio": 1.5, "block_reverse": false},
        "240": {"size_multiplier": 1.0,  "min_tier": "C", "min_tp_to_cost_ratio": 1.5, "block_reverse": false}
    }
}
